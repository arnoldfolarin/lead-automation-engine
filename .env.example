# =============================================================================
# Copy to .env and fill in real values. Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase / Firestore
# Get from: Firebase Console > Project Settings > Service accounts
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or path to service account JSON:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# -----------------------------------------------------------------------------
# OpenAI (message generation)
# Get from: platform.openai.com > API keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# SendGrid (outbound email + inbound parse)
# Get from: SendGrid dashboard
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=
# Set to true or 1 to log emails without sending
EMAIL_DRY_RUN=false

# -----------------------------------------------------------------------------
# Inbound reply handling
# -----------------------------------------------------------------------------
INBOUND_WEBHOOK_SECRET=
INBOUND_REPLY_DOMAIN=
INBOUND_REPLY_TO_EMAIL=
REPLY_TO_OVERRIDE_EMAIL=
REPLY_TO_USE_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Zapier reply webhook
# POST /api/webhooks/reply?token=REPLY_WEBHOOK_SECRET
# -----------------------------------------------------------------------------
REPLY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Meta Lead Ads ingest module (ingest/meta/)
# Get from: developers.facebook.com
# -----------------------------------------------------------------------------
META_WEBHOOK_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
TENANT_ID=default
PORT=3000

# -----------------------------------------------------------------------------
# Optional notifications
# -----------------------------------------------------------------------------
NOTIFY_EMAIL_ON_INBOUND_REVIEW=
SLACK_INBOUND_WEBHOOK_URL=
