# =============================================================================
# Copy this file to .env and fill in real values. 
# Each section below says WHERE to get the token/API key (which dashboard or doc).
# =============================================================================

# -----------------------------------------------------------------------------
# FIREBASE (Firestore) — where leads and events are stored
# Get from: Firebase Console → Project Settings → Service accounts → Generate key
# -----------------------------------------------------------------------------
# Your Firebase project ID (e.g. my-project-12345)
FIREBASE_PROJECT_ID=
# Email from the service account JSON (e.g. firebase-adminsdk-xxx@my-project.iam.gserviceaccount.com)
FIREBASE_CLIENT_EMAIL=
# The "private_key" field from the JSON; paste the full key including -----BEGIN/END-----
# If the key has \n for newlines, keep them or use real newlines.
FIREBASE_PRIVATE_KEY=

# Alternative: instead of the three above, you can use a path to the JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# -----------------------------------------------------------------------------
# META (Facebook Lead Ads webhook) — where leads come from
# Get from: developers.facebook.com → Your App → Webhooks + Marketing API
# -----------------------------------------------------------------------------
# A secret string YOU choose; Meta will send it when verifying the webhook. Must match what you set in Meta dashboard.
META_WEBHOOK_VERIFY_TOKEN=
# Page Access Token: used to call Graph API to fetch full lead details. Generate in Meta → Your App → Tools → Graph API Explorer (with leadgen permission), or use a long-lived Page token.
META_PAGE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# OPENAI — used to generate the SMS message text
# Get from: platform.openai.com → API keys → Create new secret key
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# TWILIO — used to send SMS (or dry-run log only)
# Get from: twilio.com console → Account → API keys & tokens (Account SID, Auth Token) and Phone Numbers
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio phone number that will appear as "from" when sending SMS (e.g. +15551234567)
TWILIO_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# RUNTIME — control how the backend runs
# -----------------------------------------------------------------------------
# Set to "true" to actually send SMS via Twilio. Set to "false" for Day 1 testing (only log sms_dry_run events).
SEND_MESSAGES_ENABLED=false
# Port the server listens on (e.g. 3000). Your host may override this.
PORT=3000
# Tenant ID for Firestore paths (e.g. tenants/default/...). Use "default" for single-tenant.
TENANT_ID=default

# ---------- Future expansion (optional) ----------
# Calendly webhook (see Deliverables/functions): Firebase param CALENDLY_WEBHOOK_SIGNING_SECRET
# Webhook URL: https://YOUR_HOSTING_DOMAIN/api/webhooks/calendly?tenantId=default
# SendGrid (email): API key from SendGrid dashboard; verify the sender in SendGrid before sending.
# SENDGRID_API_KEY=
# Verified single sender or domain auth (example for outreach — set in Firebase params for Cloud Functions):
# SENDGRID_FROM_EMAIL=team@tech-jump.com
# Optional override for the official transparent Tech Jump logo in outbound email signatures (defaults to hosted /assets/tech-jump-logo.png):
# EMAIL_SIGNATURE_LOGO_URL=https://tech-jump-outreach.web.app/assets/tech-jump-logo.png
# ElevenLabs (voice): API key from ElevenLabs
# ELEVENLABS_API_KEY=
# LinkedIn (sweep + send): OAuth Client ID/Secret + long-lived Access Token
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_ACCESS_TOKEN=
